generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                          @id @default(uuid())
  username                String                          @unique
  email                   String                          @unique
  password                String
  role                    Role
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  emailVerificationExpiry DateTime?
  emailVerificationToken  String?                         @unique
  isEmailVerified         Boolean                         @default(false)
  academicProfile         AcademicProfile?
  opportunityFeedback     OpportunityFeedback[]
  practicalHourEvents     PracticalHourEvent[]
  providerProfile         ProviderProfile?
  badges                  StudentBadge[]
  gamification            StudentGamification?
  opportunityInteractions StudentOpportunityInteraction[]
  studentProfile          StudentProfile?
  selectedCareers         StudentSelectedCareer[]
  xpEvents                StudentXpEvent[]
  assessmentResults       UserAssessmentResult[]
  roadmapItemProgress     UserRoadmapItemProgress[]
  roadmapTaskProgress     UserRoadmapTaskProgress[]
}

model StudentProfile {
  id                 String                   @id @default(uuid())
  userId             String                   @unique
  firstName          String
  lastName           String
  studentId          String                   @unique
  phone              String
  province           String
  birthdate          DateTime
  major              String
  educationLevel     String
  graduationYear     Int
  profilePicture     String?
  bio                String?
  academicId         String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  city               String?
  cvLink             String?
  hobbies            String[]
  interests          String[]
  onboardingStatus   OnboardingStatus         @default(PENDING_VERIFICATION)
  portfolioLink      String?
  preferences        String[]
  talents            String[]
  feedback           Feedback[]
  applications       OpportunityApplication[]
  reports            Report[]
  assessment         StudentAssessment?
  objectives         StudentObjective[]
  academic           AcademicProfile?         @relation(fields: [academicId], references: [id])
  user               User                     @relation(fields: [userId], references: [id])
  roadmapEnrollments StudentRoadmap[]
  nodeProgress       StudentRoadmapProgress[]
  skills             Skill[]                  @relation("SkillToStudentProfile")
}

model Skill {
  id       String           @id @default(uuid())
  name     String           @unique
  students StudentProfile[] @relation("SkillToStudentProfile")
}

model AcademicProfile {
  id              String           @id @default(uuid())
  userId          String           @unique
  firstName       String
  lastName        String
  phone           String
  university      String
  department      String
  role            String
  profilePicture  String?
  bio             String?
  affiliationCode String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id])
  students        StudentProfile[]
}

model ProviderProfile {
  id                  String                    @id @default(uuid())
  userId              String                    @unique
  providerType        ProviderType
  organizationName    String
  firstName           String
  lastName            String
  phone               String
  email               String
  location            String?
  website             String?
  description         String
  profilePicture      String?
  registrationNumber  String?
  verificationStatus  CompanyVerificationStatus @default(PENDING)
  accountStatus       ProviderAccountStatus     @default(ACTIVE)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  opportunities       Opportunity[]
  opportunityFeedback OpportunityFeedback[]
  user                User                      @relation(fields: [userId], references: [id])
  reports             Report[]
}

model CareerPath {
  id           String                  @id @default(uuid())
  name         String                  @unique
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  description  String?
  slug         String                  @unique
  roadmapItems CareerRoadmapItem[]
  traits       CareerTrait[]
  roadmaps     Roadmap[]
  selectedBy   StudentSelectedCareer[]
  tags         Tag[]                   @relation("CareerPathToTag")
}

model Roadmap {
  id           String           @id @default(uuid())
  name         String           @unique
  careerPathId String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  careerPath   CareerPath       @relation(fields: [careerPathId], references: [id])
  nodes        RoadmapNode[]
  enrollments  StudentRoadmap[]
}

model RoadmapNode {
  id          String                   @id @default(uuid())
  title       String
  description String
  pointValue  Int
  roadmapId   String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  roadmap     Roadmap                  @relation(fields: [roadmapId], references: [id])
  progress    StudentRoadmapProgress[]
}

model StudentRoadmap {
  id         String                @id @default(uuid())
  studentId  String
  roadmapId  String
  status     RoadmapProgressStatus @default(ENROLLED)
  enrolledAt DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  roadmap    Roadmap               @relation(fields: [roadmapId], references: [id])
  student    StudentProfile        @relation(fields: [studentId], references: [id])
}

model StudentRoadmapProgress {
  id        String             @id @default(uuid())
  studentId String
  nodeId    String
  status    NodeProgressStatus @default(NOT_STARTED)
  updatedAt DateTime           @updatedAt
  node      RoadmapNode        @relation(fields: [nodeId], references: [id])
  student   StudentProfile     @relation(fields: [studentId], references: [id])

  @@unique([studentId, nodeId])
}

model Opportunity {
  id                  String                          @id @default(uuid())
  title               String
  expectedHours       Int
  providerId          String
  description         String
  externalLink        String?
  type                OpportunityType
  workMode            WorkMode
  location            String?
  deadline            DateTime?
  capacity            Int?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  endDate             DateTime?
  isApproved          Boolean                         @default(false)
  isPublished         Boolean                         @default(false)
  startDate           DateTime?
  feedback            Feedback[]
  provider            ProviderProfile                 @relation(fields: [providerId], references: [id])
  applications        OpportunityApplication[]
  opportunityFeedback OpportunityFeedback[]
  practicalHourEvents PracticalHourEvent[]
  reports             Report[]
  studentInteractions StudentOpportunityInteraction[]
  tags                OpportunityTag[]                @relation("OpportunityToOpportunityTag")
}

model OpportunityApplication {
  id            String            @id @default(uuid())
  studentId     String
  opportunityId String
  status        OpportunityStatus @default(APPLIED)
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  opportunity   Opportunity       @relation(fields: [opportunityId], references: [id])
  student       StudentProfile    @relation(fields: [studentId], references: [id])

  @@unique([studentId, opportunityId])
}

model OpportunityTag {
  id            String        @id @default(uuid())
  name          String        @unique
  opportunities Opportunity[] @relation("OpportunityToOpportunityTag")
}

model Feedback {
  studentId     String
  opportunityId String
  rating        Int
  comment       String?
  submittedAt   DateTime       @default(now())
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id])
  student       StudentProfile @relation(fields: [studentId], references: [id])

  @@id([studentId, opportunityId])
}

model Report {
  id            String          @id @default(uuid())
  studentId     String
  providerId    String
  createdAt     DateTime        @default(now())
  adminNotes    String?
  description   String
  opportunityId String?
  reviewedAt    DateTime?
  reviewedBy    String?
  status        ReportStatus    @default(PENDING)
  updatedAt     DateTime        @updatedAt
  reason        ReportReason
  opportunity   Opportunity?    @relation(fields: [opportunityId], references: [id])
  provider      ProviderProfile @relation(fields: [providerId], references: [id])
  student       StudentProfile  @relation(fields: [studentId], references: [id])

  @@index([studentId, providerId])
  @@index([providerId, status])
  @@index([status, createdAt])
}

model SystemConfig {
  key   String @id
  value String
}

model Level {
  level          Int @id
  requiredPoints Int
}

model Tag {
  id           String                @id @default(uuid())
  label        String                @unique
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  key          String                @unique
  options      AssessmentOptionTag[]
  careerTraits CareerTrait[]
  careers      CareerPath[]          @relation("CareerPathToTag")
}

model AssessmentQuestion {
  id           String                    @id @default(uuid())
  question     String
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  assessmentId String
  order        Int
  options      AssessmentOption[]
  assessment   Assessment                @relation(fields: [assessmentId], references: [id])
  answer       StudentAssessmentAnswer[]
}

model AssessmentOption {
  id         String                    @id @default(uuid())
  option     String
  questionId String
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  order      Int
  question   AssessmentQuestion        @relation(fields: [questionId], references: [id])
  tags       AssessmentOptionTag[]
  answer     StudentAssessmentAnswer[]
}

model AssessmentOptionTag {
  optionId String
  tagId    String
  weight   Int
  option   AssessmentOption @relation(fields: [optionId], references: [id])
  tag      Tag              @relation(fields: [tagId], references: [id])

  @@id([optionId, tagId])
}

model StudentAssessment {
  id        String                    @id @default(uuid())
  studentId String                    @unique
  status    AssessmentProgressStatus  @default(IN_PROGRESS)
  takenAt   DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  student   StudentProfile            @relation(fields: [studentId], references: [id])
  answer    StudentAssessmentAnswer[]
}

model StudentAssessmentAnswer {
  id           String             @id @default(uuid())
  assessmentId String
  questionId   String
  optionId     String
  assessment   StudentAssessment  @relation(fields: [assessmentId], references: [id])
  option       AssessmentOption   @relation(fields: [optionId], references: [id])
  question     AssessmentQuestion @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
}

model Assessment {
  id          String                 @id @default(uuid())
  title       String
  description String?
  isActive    Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  questions   AssessmentQuestion[]
  results     UserAssessmentResult[]
}

model CareerTrait {
  id       String     @id @default(uuid())
  careerId String
  tagId    String
  value    Float
  career   CareerPath @relation(fields: [careerId], references: [id])
  tag      Tag        @relation(fields: [tagId], references: [id])

  @@unique([careerId, tagId])
}

model RoadmapTopic {
  id      String              @id @default(uuid())
  name    String              @unique
  slug    String              @unique
  careers CareerRoadmapItem[]
}

model CareerRoadmapItem {
  id           String                    @id @default(uuid())
  careerId     String
  topicId      String
  order        Int
  career       CareerPath                @relation(fields: [careerId], references: [id])
  topic        RoadmapTopic              @relation(fields: [topicId], references: [id])
  tasks        RoadmapTask[]
  userProgress UserRoadmapItemProgress[]

  @@unique([careerId, topicId])
}

model UserAssessmentResult {
  id               String     @id @default(uuid())
  userId           String?
  assessmentId     String
  submittedAnswers Json
  rawScores        Json
  normalizedScores Json
  careerMatches    Json
  createdAt        DateTime   @default(now())
  assessment       Assessment @relation(fields: [assessmentId], references: [id])
  user             User?      @relation(fields: [userId], references: [id])

  @@unique([userId, assessmentId])
}

model OnboardingObjective {
  id        String             @id @default(uuid())
  key       String             @unique
  label     String
  createdAt DateTime           @default(now())
  students  StudentObjective[]
}

model StudentObjective {
  id          String              @id @default(uuid())
  studentId   String
  objectiveId String
  createdAt   DateTime            @default(now())
  objective   OnboardingObjective @relation(fields: [objectiveId], references: [id])
  student     StudentProfile      @relation(fields: [studentId], references: [id])

  @@unique([studentId, objectiveId])
}

model StudentSelectedCareer {
  id           String     @id @default(uuid())
  userId       String
  careerPathId String
  selectedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, careerPathId])
}

model RoadmapTask {
  id            String                    @id @default(uuid())
  roadmapItemId String
  title         String
  description   String?
  order         Int
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  roadmapItem   CareerRoadmapItem         @relation(fields: [roadmapItemId], references: [id])
  userProgress  UserRoadmapTaskProgress[]
}

model UserRoadmapItemProgress {
  id                 String            @id @default(uuid())
  userId             String
  roadmapItemId      String
  status             RoadmapItemStatus @default(NOT_STARTED)
  progressPercentage Float             @default(0)
  completedAt        DateTime?
  pointsAwarded      Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  roadmapItem        CareerRoadmapItem @relation(fields: [roadmapItemId], references: [id])
  user               User              @relation(fields: [userId], references: [id])

  @@unique([userId, roadmapItemId])
}

model UserRoadmapTaskProgress {
  id          String      @id @default(uuid())
  userId      String
  taskId      String
  isCompleted Boolean     @default(false)
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  task        RoadmapTask @relation(fields: [taskId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([userId, taskId])
}

model StudentGamification {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  totalXp                Int      @default(0)
  level                  Int      @default(1)
  currentLevelXp         Int      @default(0)
  nextLevelXp            Int      @default(100)
  verifiedPracticalHours Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id])
}

model StudentXpEvent {
  id         String   @id @default(uuid())
  userId     String
  sourceType String
  sourceId   String
  xpAmount   Int
  reason     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, sourceType, sourceId])
}

model PracticalHourEvent {
  id            String               @id @default(uuid())
  userId        String
  hours         Int
  sourceType    String
  sourceId      String
  opportunityId String?
  feedbackId    String?
  description   String?
  createdAt     DateTime             @default(now())
  feedback      OpportunityFeedback? @relation(fields: [feedbackId], references: [id])
  opportunity   Opportunity?         @relation(fields: [opportunityId], references: [id])
  user          User                 @relation(fields: [userId], references: [id])

  @@unique([userId, sourceType, sourceId])
}

model StudentBadge {
  id        String   @id @default(uuid())
  badgeId   String
  createdAt DateTime @default(now())
  earnedAt  DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
}

model StudentOpportunityInteraction {
  id                    String                       @id @default(uuid())
  userId                String
  opportunityId         String
  status                OpportunityInteractionStatus @default(INTERESTED)
  interestedAt          DateTime                     @default(now())
  attendanceConfirmedAt DateTime?
  participated          Boolean?
  feedbackSubmittedAt   DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  opportunity           Opportunity                  @relation(fields: [opportunityId], references: [id])
  user                  User                         @relation(fields: [userId], references: [id])

  @@unique([userId, opportunityId])
}

model OpportunityFeedback {
  id                  String               @id @default(uuid())
  userId              String
  opportunityId       String
  providerId          String
  ratingOverall       Int
  ratingContent       Int?
  ratingOrganization  Int?
  ratingCommunication Int?
  comment             String?
  isAnonymous         Boolean              @default(true)
  createdAt           DateTime             @default(now())
  opportunity         Opportunity          @relation(fields: [opportunityId], references: [id])
  provider            ProviderProfile      @relation(fields: [providerId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  practicalHourEvents PracticalHourEvent[]

  @@unique([userId, opportunityId])
}

enum Role {
  STUDENT
  ACADEMIC
  PROVIDER
  ADMIN
}

enum ProviderType {
  UNIVERSITY
  TRAINING_CENTER
  COMPANY
}

enum WorkMode {
  ONLINE
  ONSITE
  HYBRID
}

enum CompanyVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OpportunityType {
  INTERNSHIP
  WORKSHOP
  VOLUNTEERING
  COURSE
}

enum OpportunityStatus {
  APPLIED
  ACCEPTED
  REJECTED
  ENROLLED
  COMPLETED
}

enum NodeProgressStatus {
  NOT_STARTED
  COMPLETED
}

enum RoadmapProgressStatus {
  ENROLLED
  COMPLETED
  ABANDONED
}

enum RoadmapItemStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ProviderAccountStatus {
  ACTIVE
  WARNED
  SUSPENDED
}

enum AssessmentProgressStatus {
  IN_PROGRESS
  COMPLETED
}

enum OnboardingStatus {
  PENDING_VERIFICATION
  PENDING_ONBOARDING
  COMPLETED
}

enum OpportunityInteractionStatus {
  INTERESTED
  NOT_PARTICIPATED
  PARTICIPATED
  FEEDBACK_SUBMITTED
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum ReportReason {
  MISLEADING_INFORMATION
  UNPROFESSIONAL_BEHAVIOR
  SCAM_OR_FRAUD
  INAPPROPRIATE_CONTENT
  SAFETY_CONCERN
  DISCRIMINATION_OR_HARASSMENT
  OTHER
}
