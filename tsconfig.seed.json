{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false
  },
  "include": ["prisma/**/*.ts", "src/**/*.ts"]
}
